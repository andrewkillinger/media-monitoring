# PostgreSQL - Required
DATABASE_URL=postgresql://user:password@localhost:5432/media_monitoring

# Cron job secret - Required for scheduled ingestion API calls
CRON_SECRET=your-cron-secret

# Optional: AI summarization (leave blank to disable)
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# Optional: Email delivery for alerts and digests
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM_EMAIL=media-monitor@example.com

# Optional: Translation provider
TRANSLATION_API_KEY=
TRANSLATION_PROVIDER=

# Optional: Resend for email (alternative to SMTP)
RESEND_API_KEY=
