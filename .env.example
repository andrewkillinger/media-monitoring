# Supabase - Required
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron job secret - Required for scheduled ingestion
CRON_SECRET=your-cron-secret

# Allowed email domains for signup (comma-separated)
ALLOWED_EMAIL_DOMAINS=acadia.com

# Optional: AI summarization (leave blank to disable)
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# Optional: Email delivery for alerts and digests
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM_EMAIL=media-monitor@acadia.com

# Optional: Translation provider
TRANSLATION_API_KEY=
TRANSLATION_PROVIDER=

# Optional: Resend for email (alternative to SMTP)
RESEND_API_KEY=
